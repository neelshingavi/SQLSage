POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sqlsage
POSTGRES_DB=sqlsage

SQLSAGE_TIMEOUT_MS=120000

# Training (HF Space runtime)
SQLSAGE_ENV_URL=https://adity00-sqlsage-env.hf.space/
WANDB_API_KEY=replace_with_your_wandb_api_key
WANDB_PROJECT=sqlsage-grpo
WANDB_RUN_NAME=rollout-http
SQLSAGE_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# GRPO: real obs + make_prompt (default). Set=1 for short generic prompt smoke tests.
# SQLSAGE_TRAIN_PLAIN_PROMPT=0
# SQLSAGE_TRAIN_DATASET_SIZE=256
# SQLSAGE_MAX_SEQ_LENGTH=2048
SQLSAGE_OUTPUT_DIR=sqlsage-trained
SQLSAGE_MERGED_DIR=sqlsage-trained-merged

# Hugging Face (optional): write token for `openenv push` / Hub uploads — never commit a real value
# HF_TOKEN=hf_...
# Optional override: HF_SPACE_REPO_ID=YourUser/sqlsage-env
